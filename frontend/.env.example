# Frontend env example. Giphy is configured on the backend (GIPHY_API_KEY or giphy.api-key in application-secret.properties).
VITE_AUTH0_DOMAIN=your-tenant.us.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-spa-client-id
VITE_AUTH0_AUDIENCE=urn:your-api

# Async PDF job polling interval in milliseconds (default: 2000)
# VITE_PDF_JOB_POLL_INTERVAL_MS=2000

# Playwright E2E: test user for Auth0 login (optional; if missing, Auth0 E2E tests are skipped)
# AUTH0_E2E_EMAIL=your-test-user@example.com
# AUTH0_E2E_PASSWORD=your-test-password
